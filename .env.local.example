# Zenn記事のGitHubリポジトリ（GitHub アカウント名/リポジトリ名）
ZENN_GH_REPO=nekoneko02/zenn

# Zenn の公開URLで使うユーザー名（GitHub アカウント名と異なる場合に設定）
ZENN_USERNAME=neko_student

# note の RSS URL
NOTE_RSS_URL=https://note.com/alg_geo/rss

# GitHub API レート緩和（GitHub Actions では自動付与、ローカルでは任意）
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Google Analytics 計測ID（本番環境のみ設定、ローカルは未設定でよい）
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Amplify ビルドトリガー Webhook（スケジュール再ビルド用、Secrets に格納）
# AMPLIFY_BUILD_WEBHOOK=https://...
